{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": ["backend/**", "node_modules/sql.js/dist/sql-wasm.wasm"],
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
